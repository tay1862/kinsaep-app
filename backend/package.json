{
  "name": "kinsaep-pos-backend",
  "version": "1.0.0",
  "description": "Kinsaep POS - Multi-Tenant SaaS Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "pos",
    "saas",
    "multi-tenant"
  ],
  "author": "Kinsaep",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.2",
    "prisma": "6.19.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
