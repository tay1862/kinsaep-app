generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  phone        String?
  role         UserRole @default(OWNER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stores       Store[]
  activityLogs ActivityLog[]
}

model Store {
  id               String            @id @default(uuid())
  name             String
  address          String?
  phone            String?
  businessType     String            @default("retail")
  currency         String            @default("LAK")
  locale           String            @default("lo")
  taxEnabled       Boolean           @default(false)
  taxRate          Float             @default(0)
  receiptHeader    String?
  receiptFooter    String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ownerId          String
  owner            User              @relation(fields: [ownerId], references: [id])

  subscription     Subscription?
  entitlement      StoreEntitlement?
  staff            Staff[]
  categories       Category[]
  items            Item[]
  sales            Sale[]
  shifts           Shift[]
  salesSummaries   SalesSummary[]
  devices          Device[]
  kitchenStations  KitchenStation[]
  kitchenScreens   KitchenScreen[]
  kitchenTickets   KitchenTicket[]
  mediaAssets      MediaAsset[]
  syncJobs         SyncJob[]
  tombstones       Tombstone[]
  activityLogs     ActivityLog[]
}

model Subscription {
  id          String             @id @default(uuid())
  storeId     String             @unique
  store       Store              @relation(fields: [storeId], references: [id])
  plan        SubscriptionPlan   @default(FREE)
  status      SubscriptionStatus @default(BLOCKED)
  validUntil  DateTime
  trialEndsAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model PackageTemplate {
  id                String             @id @default(uuid())
  code              String             @unique
  name              String
  description       String?
  maxStaff          Int                @default(1)
  maxDevices        Int                @default(1)
  maxKitchenScreens Int                @default(0)
  maxStations       Int                @default(0)
  allowMediaUpload  Boolean            @default(false)
  maxSyncProfile    SyncProfile        @default(OFF)
  retainRawSalesDays Int               @default(0)
  allowRawSalesSync Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  entitlements      StoreEntitlement[]
}

model StoreEntitlement {
  id                 String          @id @default(uuid())
  storeId            String          @unique
  store              Store           @relation(fields: [storeId], references: [id])
  packageTemplateId  String?
  packageTemplate    PackageTemplate? @relation(fields: [packageTemplateId], references: [id])
  maxStaff           Int?
  maxDevices         Int?
  maxKitchenScreens  Int?
  maxStations        Int?
  allowMediaUpload   Boolean?
  maxSyncProfile     SyncProfile?
  retainRawSalesDays Int?
  allowRawSalesSync  Boolean         @default(false)
  overrideReason     String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Staff {
  id            String    @id @default(uuid())
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id])
  name          String
  pin           String
  pinLocalHash  String
  role          StaffRole @default(CASHIER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  activityLogs  ActivityLog[]
}

model Category {
  id          String    @id @default(uuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  name        String
  color       Int       @default(4282155766)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items       Item[]
}

model Item {
  id                String              @id @default(uuid())
  storeId           String
  store             Store               @relation(fields: [storeId], references: [id])
  categoryId        String?
  category          Category?           @relation(fields: [categoryId], references: [id])
  kitchenStationId  String?
  kitchenStation    KitchenStation?     @relation(fields: [kitchenStationId], references: [id])
  name              String
  price             Float               @default(0)
  cost              Float               @default(0)
  barcode           String?
  sku               String?
  trackStock        Boolean             @default(false)
  stockQty          Float               @default(0)
  lowStockAt        Float               @default(5)
  modifiers         Json                @default("[]")
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  saleItems         SaleItem[]
  mediaAssets       MediaAsset[]
  kitchenTicketItems KitchenTicketItem[]
}

model SalesSummary {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  businessDay String
  totalOrders Int      @default(0)
  totalSales  Float    @default(0)
  cashTotal   Float    @default(0)
  otherTotal  Float    @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([storeId, businessDay])
}

model Device {
  id            String         @id
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id])
  name          String
  type          DeviceType     @default(POS)
  platform      DevicePlatform @default(ANDROID)
  scannerMode   ScannerMode    @default(AUTO)
  syncProfile   SyncProfile    @default(OFF)
  isActive      Boolean        @default(true)
  status        DeviceStatus   @default(OFFLINE)
  lastSeenAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  sales         Sale[]
  kitchenScreens KitchenScreen[]
  kitchenTickets KitchenTicket[]
  mediaAssets   MediaAsset[]
  syncJobs      SyncJob[]
}

model KitchenStation {
  id          String             @id @default(uuid())
  storeId     String
  store       Store              @relation(fields: [storeId], references: [id])
  name        String
  type        KitchenStationType
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  items       Item[]
  screens     KitchenScreen[]
  ticketItems KitchenTicketItem[]
}

model KitchenScreen {
  id          String          @id @default(uuid())
  storeId     String
  store       Store           @relation(fields: [storeId], references: [id])
  stationId   String
  station     KitchenStation  @relation(fields: [stationId], references: [id])
  deviceId    String
  device      Device          @relation(fields: [deviceId], references: [id])
  label       String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([storeId, deviceId])
}

model KitchenTicket {
  id           String             @id @default(uuid())
  storeId      String
  store        Store              @relation(fields: [storeId], references: [id])
  saleId       String?            @unique
  sale         Sale?              @relation(fields: [saleId], references: [id])
  sourceDeviceId String?
  sourceDevice Device?            @relation(fields: [sourceDeviceId], references: [id])
  status       KitchenTicketStatus @default(NEW)
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  items        KitchenTicketItem[]
}

model KitchenTicketItem {
  id          String              @id @default(uuid())
  ticketId    String
  ticket      KitchenTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  itemId      String?
  item        Item?               @relation(fields: [itemId], references: [id])
  stationId   String?
  station     KitchenStation?     @relation(fields: [stationId], references: [id])
  itemName    String
  quantity    Float               @default(1)
  status      KitchenTicketStatus @default(NEW)
  note        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model MediaAsset {
  id            String         @id @default(uuid())
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id])
  itemId        String?
  item          Item?          @relation(fields: [itemId], references: [id])
  deviceId      String?
  device        Device?        @relation(fields: [deviceId], references: [id])
  type          MediaAssetType @default(ITEM_IMAGE)
  fileName      String
  mimeType      String
  thumbnailPath String
  width         Int?
  height        Int?
  fileSize      Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model SyncJob {
  id           String        @id @default(uuid())
  storeId      String
  store        Store         @relation(fields: [storeId], references: [id])
  deviceId     String?
  device       Device?       @relation(fields: [deviceId], references: [id])
  direction    SyncDirection
  syncProfile  SyncProfile
  status       SyncJobStatus @default(QUEUED)
  progress     Int           @default(0)
  scopes       Json?
  counts       Json?
  error        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  completedAt  DateTime?
}

model Tombstone {
  id         String              @id @default(uuid())
  storeId    String
  store      Store               @relation(fields: [storeId], references: [id])
  entityType TombstoneEntityType
  entityId    String
  payload    Json?
  deletedAt  DateTime            @default(now())
  createdAt  DateTime            @default(now())

  @@index([storeId, deletedAt])
}

model Sale {
  id              String   @id @default(uuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id])
  deviceId        String?
  device          Device?  @relation(fields: [deviceId], references: [id])
  receiptNumber   String
  subtotal        Float    @default(0)
  discountAmount  Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  amountPaid      Float    @default(0)
  changeAmount    Float    @default(0)
  paymentMethod   String   @default("cash")
  status          String   @default("completed")
  ticketName      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           SaleItem[]
  kitchenTicket   KitchenTicket?
}

model SaleItem {
  id         String @id @default(uuid())
  saleId     String
  sale       Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item   @relation(fields: [itemId], references: [id])
  itemName   String
  quantity   Float  @default(1)
  unitPrice  Float  @default(0)
  totalPrice Float  @default(0)
}

model Shift {
  id           String   @id @default(uuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  startingCash Float    @default(0)
  cashAdded    Float    @default(0)
  cashRemoved  Float    @default(0)
  expectedCash Float?
  actualCash   Float?
  difference   Float?
  status       String   @default("open")
}

model ActivityLog {
  id        String   @id @default(uuid())
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  staffId   String?
  staff     Staff?   @relation(fields: [staffId], references: [id])
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  OWNER
}

enum SubscriptionPlan {
  FREE_TRIAL
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  BLOCKED
  CANCELLED
}

enum StaffRole {
  OWNER
  MANAGER
  CASHIER
}

enum SyncProfile {
  OFF
  LIGHT
  FULL
}

enum DeviceType {
  POS
  KITCHEN
  MANAGER
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  BLOCKED
}

enum ScannerMode {
  AUTO
  CAMERA
  HID
  SUNMI
  ZEBRA
}

enum KitchenStationType {
  HOT
  COLD
  DRINK
}

enum KitchenTicketStatus {
  NEW
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum MediaAssetType {
  ITEM_IMAGE
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum SyncDirection {
  PUSH
  PULL
  FULL_SYNC
}

enum TombstoneEntityType {
  CATEGORY
  ITEM
  STAFF
  DEVICE
  KITCHEN_STATION
  KITCHEN_SCREEN
  MEDIA_ASSET
}
